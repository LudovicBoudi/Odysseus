; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Odysseus"
run/main_scene="res://src/Main.tscn"
config/features=PackedStringArray("4.3", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SaveManager="*res://src/Data/SaveManager.cs"
GameStateManager="*res://src/Managers/GameStateManager.cs"

[dotnet]

project/assembly_name="Odysseus"

[editor_plugins]

enabled=PackedStringArray("res://addons/asset_placer/plugin.cfg", "res://addons/terrain_3d/plugin.cfg")
